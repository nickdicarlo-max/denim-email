# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:6543/postgres?pgbouncer=true&connection_limit=5
DIRECT_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Google OAuth (for Gmail API)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Token encryption
TOKEN_ENCRYPTION_KEY=

# AI APIs (Phase 1+)
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_AI_API_KEY=

# Inngest
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Testing
TEST_DATABASE_URL=
BYPASS_AUTH=false

# Eval AI response cache (dev-only — never set in production).
# off:     disabled (default). Every AI call hits the provider.
# fixture: consult .eval-cache/ai/ before calling; persist misses.
# record:  always call the provider AND persist (overwrites cache).
AI_RESPONSE_CACHE=off
