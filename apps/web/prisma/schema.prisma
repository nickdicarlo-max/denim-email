// =============================================================================
// GENERIC CASE ENGINE — DATABASE SCHEMA
// =============================================================================
// 
// Supabase PostgreSQL via Prisma ORM
// 
// Design principles:
//   1. Metadata-first: Store enough per-email that we rarely re-fetch from Gmail
//   2. Two-axis entities: Primary (boundary) + Secondary[] (signal)
//   3. CaseSchema as configuration: Interview-generated, user-tunable
//   4. Feedback as first-class data: Every correction teaches the system
//   5. Attachment inventory: Know what exists, summarize it, re-fetch only when needed
//
// Key relationships:
//   User -> CaseSchema[] (one per "topic" they organize)
//   CaseSchema -> Entity[] (primary + secondary entities)
//   CaseSchema -> SchemaTag[] (tag taxonomy)
//   CaseSchema -> ExtractedFieldDef[] (configurable data extraction)
//   CaseSchema -> Email[] -> EmailAttachment[]
//   CaseSchema -> Case[] -> CaseEmail[] (junction to emails)
//   CaseSchema -> FeedbackEvent[] (corrections, ratings)
//   CaseSchema -> QualitySnapshot[] (daily accuracy tracking)
//
// Last updated: 2026-03-05
// =============================================================================

generator client {
  provider = "prisma-client"
  output   = "./generated/prisma/client"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// USER & AUTH
// =============================================================================

model User {
  id            String   @id    // Supabase auth.users.id (UUID), no auto-generate
  email         String   @unique
  displayName   String?
  avatarUrl     String?

  // OAuth tokens (encrypted at rest via AES-256-GCM)
  // Stored as encrypted string: "iv_hex:authTag_hex:ciphertext_hex"
  // Decrypts to JSON: { access_token, refresh_token, expiry_date, scope }
  googleTokens  String?

  // User-level settings
  timezone      String   @default("America/Chicago")
  
  // Relationships
  schemas       CaseSchema[]
  scanJobs      ScanJob[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Deletion audit (GDPR)
  deletedAt     DateTime?

  @@map("users")
}


// =============================================================================
// CASE SCHEMA — The Interview-Generated Configuration
// =============================================================================
// 
// Each schema represents one "topic" the user organizes.
// Created via the onboarding interview, reusable for adding new topics.
// Contains all configuration the clustering engine and extraction pipeline need.
// =============================================================================

model CaseSchema {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Identity
  name          String                  // "Harbor View Renovation", "My Law Practice"
  description   String   @db.Text       // User's original description from Card 1
  domain        String?                 // "school_parent", "property", "construction", "legal", "agency", "general"
  status        SchemaStatus @default(DRAFT)

  // Raw interview answers (for debugging, re-interview, analytics)
  interviewResponses  Json?             // { role, followUp, whats[], whos[], context }
  rawHypothesis       Json?             // Full AI-generated hypothesis JSON (for debugging)

  // --- PRIMARY ENTITY CONFIG ---
  // The "boundary" axis: cases never cross primary entity lines
  primaryEntityConfig  Json             // { name, description, autoDetect, internalDomains[] }
  // Example: { name: "Project", description: "Construction project or job site",
  //            autoDetect: true, internalDomains: ["@mycompany.com"] }

  // --- SECONDARY ENTITY CONFIG ---
  // The "signal" axis: provides affinity scoring within primary entity boundaries
  // Stored as JSON array since the structure is lightweight and rarely queried directly
  secondaryEntityConfig  Json?          // [{ name, description, derivedFrom, affinityScore }]
  // Example: [{ name: "Vendor", description: "Contractors and service providers",
  //             derivedFrom: "sender", affinityScore: 30 }]

  // --- EMAIL DISCOVERY ---
  // Gmail search queries generated by the interview
  discoveryQueries  Json               // [{ query: string, label: string }]

  // --- CASE STRUCTURE ---
  // Beginning / Middle / End labels (domain-specific)
  summaryLabels     Json               // { beginning: "Issue", middle: "Activity", end: "Status" }

  // --- AI PROMPTS ---
  // Generated by the interview, used by extraction and synthesis pipelines
  extractionPrompt  String  @db.Text    // Instructions for Gemini: what to extract per email
  synthesisPrompt   String  @db.Text    // Instructions for Claude: how to synthesize cases

  // --- CLUSTERING CONFIG ---
  // Proven defaults from TCS, tunable per schema
  clusteringConfig  Json               // See ClusteringConfig type below

  // --- LEARNING LOOP ---
  qualityPhase            String  @default("CALIBRATING")  // CALIBRATING | TRACKING | STABLE
  calibrationRunCount     Int     @default(0)
  tunedClusteringConfig   Json?   // Learned gravity params (overrides clusteringConfig when set)
  discriminatorVocabulary Json?   // Learned discriminators per entity
  // Default: { mergeThreshold: 45, tagMatchScore: 60, subjectMatchScore: 50,
  //            weakTagDiscount: 0.3, anchorTagLimit: 2, timeDecayDays: { fresh: 45, recent: 75, stale: 120 },
  //            caseSizeThreshold: 10, caseSizeMaxBonus: 25, subjectAdditiveBonus: 25,
  //            stopWords: [], autoFrequencyDiscount: true, frequencyThreshold: 0.30 }

  // --- SCAN CONFIG ---
  defaultScanDepthDays  Int  @default(90)  // How far back to scan on initial setup
  lastFullScanAt        DateTime?          // When the full scan last ran
  scanFrequency         String @default("daily")  // "manual" | "daily" | "hourly"

  // --- CO-PILOT CONFIG (Phase 2) ---
  copilotConfig     Json?              // { enabled, startedAt, expiresAt, adjustmentsApplied }

  // Counts (denormalized for performance)
  emailCount        Int      @default(0)
  caseCount         Int      @default(0)

  // Relationships
  tags              SchemaTag[]
  extractedFields   ExtractedFieldDef[]
  entities          Entity[]
  entityGroups      EntityGroup[]
  emails            Email[]
  cases             Case[]
  clusters          Cluster[]
  feedbackEvents    FeedbackEvent[]
  qualitySnapshots  QualitySnapshot[]
  scanJobs          ScanJob[]
  exclusionRules    ExclusionRule[]
  pipelineIntelligence PipelineIntelligence[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
  @@map("case_schemas")
}

enum SchemaStatus {
  DRAFT         // Interview in progress
  ONBOARDING    // Initial scan running
  ACTIVE        // Normal operation
  PAUSED        // User paused scanning
}


// =============================================================================
// TAG TAXONOMY
// =============================================================================
//
// Tags are the "WHAT" dimension. AI-generated during interview, user-adjustable.
// Weights control clustering: higher weight = stronger merge signal.
// Auto-frequency discount prevents high-frequency tags from bridging unrelated cases.
// =============================================================================

model SchemaTag {
  id            String   @id @default(cuid())
  schemaId      String
  schema        CaseSchema @relation(fields: [schemaId], references: [id], onDelete: Cascade)

  name          String                  // "Permits", "HVAC", "Contract Review"
  kind          String   @default("CATEGORY") // CATEGORY | DISCRIMINATOR
  description   String?  @db.Text       // For AI extraction guidance

  // Weights
  userWeight    Float?                  // User override (null = use autoWeight)
  autoWeight    Float    @default(1.0)  // Data-driven, updated after each scan
  // Effective weight at runtime: userWeight ?? autoWeight

  // Metadata
  aiGenerated   Boolean  @default(true) // Created by interview vs manually added
  isActive      Boolean  @default(true) // User can disable on Card 4 without deleting
  emailCount    Int      @default(0)    // How many emails have this tag
  frequency     Float    @default(0)    // emailCount / schema.emailCount (for TF-IDF discount)
  isWeak        Boolean  @default(false) // Auto-set when frequency > schema.clusteringConfig.frequencyThreshold

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([schemaId, name])
  @@index([schemaId, isActive])
  @@map("schema_tags")
}


// =============================================================================
// EXTRACTED FIELD DEFINITIONS
// =============================================================================
//
// Configurable data extraction per schema. Defines what fields to pull from emails
// and how to display/aggregate them.
// =============================================================================

model ExtractedFieldDef {
  id            String   @id @default(cuid())
  schemaId      String
  schema        CaseSchema @relation(fields: [schemaId], references: [id], onDelete: Cascade)

  name          String                  // "cost", "deadline", "contractDate"
  type          FieldType               // number, string, date, boolean
  description   String   @db.Text       // For AI extraction: "Dollar amount from invoices"
  
  // Source hint for extraction pipeline
  source        FieldSource @default(ANY) // Where to look: body only, attachment only, or both
  
  // Display configuration
  format        String?                 // "currency", "relative", "date", "percentage"
  showOnCard    Boolean  @default(false) // Surface on case card in feed (max 1-2 per schema)
  
  // Aggregation: how to roll up email-level values to case-level
  aggregation   AggregationType @default(LATEST) // sum, latest, max, min, count, first

  sortOrder     Int      @default(0)    // Display ordering

  @@unique([schemaId, name])
  @@index([schemaId])
  @@map("extracted_field_defs")
}

enum FieldType {
  NUMBER
  STRING
  DATE
  BOOLEAN
}

enum FieldSource {
  BODY          // Only extract from email body text
  ATTACHMENT    // Only extract from attachments
  ANY           // Extract from either
}

enum AggregationType {
  SUM           // Add up all values (cost)
  LATEST        // Most recent value (deadline)
  MAX           // Highest value
  MIN           // Lowest value
  COUNT         // Number of non-null occurrences
  FIRST         // First chronological value
}


// =============================================================================
// ENTITY GROUPS — Paired WHAT+WHO Relationships
// =============================================================================
//
// Groups capture the natural pairings from the interview: Soccer↔Ziad Allan,
// Dance↔Lanier↔Ms Garza, St Agnes alone. Groups are the source of truth for
// associatedPrimaryIds (derivable: secondary's group → find PRIMARYs in same group).
// =============================================================================

model EntityGroup {
  id        String     @id @default(cuid())
  schemaId  String
  schema    CaseSchema @relation(fields: [schemaId], references: [id], onDelete: Cascade)
  index     Int        // 0, 1, 2... for display ordering

  entities  Entity[]   // All entities (PRIMARY + SECONDARY) in this group

  createdAt DateTime   @default(now())

  @@index([schemaId])
  @@map("entity_groups")
}


// =============================================================================
// ENTITIES — Two-Axis Model
// =============================================================================
//
// Primary entities define case boundaries (cases never cross primary entity lines).
// Secondary entities provide scoring signal within those boundaries.
// Both can be auto-detected from email patterns or manually defined.
// =============================================================================

model Entity {
  id            String   @id @default(cuid())
  schemaId      String
  schema        CaseSchema @relation(fields: [schemaId], references: [id], onDelete: Cascade)

  name          String                  // "Harbor View Renovation", "Acme Corp"
  type          EntityType              // PRIMARY or SECONDARY
  
  // For secondary entities: which config entry this belongs to
  // e.g., "Vendor", "Architect", "Inspector" (references secondaryEntityConfig[].name)
  secondaryTypeName  String?            // null for primary entities
  
  // Aliases for fuzzy matching
  aliases       Json     @default("[]") // ["Harbor View", "HV Reno", "123 Harbor View Dr"]
  
  // Group membership (source of truth for WHAT+WHO pairings)
  groupId   String?
  group     EntityGroup? @relation(fields: [groupId], references: [id])

  // Associations (secondary entities linked to primary entities)
  // Denormalized cache — derivable from group membership
  associatedPrimaryIds  Json  @default("[]")  // Entity IDs of primary entities this secondary works with

  // Detection metadata
  autoDetected  Boolean  @default(true) // Discovered by AI vs manually added
  confidence    Float    @default(1.0)  // How confident the auto-detection was
  isActive      Boolean  @default(true) // User can disable on Card 4 without deleting
  emailCount    Int      @default(0)    // How many emails reference this entity
  
  // Relationships
  emails        Email[]                 // Emails assigned to this entity (primary only)
  cases         Case[]                  // Cases scoped to this entity (primary only)
  
  // Secondary entity relationships to emails (for sender matching)
  senderEmails  Email[]  @relation("SenderEntity")

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([schemaId, name, type])
  @@index([schemaId, type, isActive])
  @@map("entities")
}

enum EntityType {
  PRIMARY       // Boundary: "Property", "Client", "Project"
  SECONDARY     // Signal: "Vendor", "Opposing Counsel", "Contractor"
}


// =============================================================================
// EMAIL — The Rich Metadata Record
// =============================================================================
//
// This is the search index. Detailed enough to answer most questions without
// re-fetching from Gmail. Every field is chosen to support:
//   - Clustering decisions (tags, entities, threadId, date)
//   - Search/triangulation (subject, sender, extractedData, attachment summaries)
//   - Debugging (routingDecision, clusteringConfidence)
//   - Re-fetch targeting (gmailMessageId, gmailAttachmentIds)
// =============================================================================

model Email {
  id            String   @id @default(cuid())
  schemaId      String
  schema        CaseSchema @relation(fields: [schemaId], references: [id], onDelete: Cascade)

  // --- ENTITY ASSIGNMENT ---
  entityId      String?                 // Primary entity this email belongs to
  entity        Entity?  @relation(fields: [entityId], references: [id], onDelete: SetNull)
  
  // Sender entity (secondary entity match)
  senderEntityId  String?
  senderEntity    Entity? @relation("SenderEntity", fields: [senderEntityId], references: [id], onDelete: SetNull)

  // --- GMAIL REFERENCE (for re-fetching) ---
  gmailMessageId  String                // Gmail unique ID
  threadId        String                // Gmail thread ID (critical for clustering)
  historyId       String?               // Gmail change tracking ID
  
  // --- HEADER DATA (always available, zero cost) ---
  subject         String
  sender          String                // Full "Display Name <email>" string
  senderEmail     String                // Parsed: user@domain.com
  senderDomain    String                // Parsed: domain.com
  senderDisplayName String              // Parsed: "Display Name"
  recipients      Json    @default("[]") // To + CC addresses as string array
  date            DateTime              // Email date (for sorting and time decay)
  isReply         Boolean @default(false) // Subject starts with RE:/FW:
  threadPosition  Int     @default(1)   // Position in thread (1 = first message)

  // --- AI EXTRACTION (from first pass) ---
  summary         String   @db.Text     // 1-2 sentence AI summary
  tags            Json     @default("[]") // String array: AI-extracted, maps to SchemaTag names
  discriminators  Json     @default("[]") // String array: discriminator words assigned during case splitting
  extractedData   Json     @default("{}") // Schema-defined fields: { cost: 8200, deadline: "2026-04-01" }
  
  // Body metadata (useful for search without storing full body)
  bodyLength      Int      @default(0)  // Character count
  language        String?               // Detected language code: "en", "es"
  
  // Entity detection results (all entities mentioned, not just assigned)
  detectedEntities  Json   @default("[]") // [{ name, type, confidence }]
  isInternal        Boolean @default(false) // Sender is from an internal domain

  // --- ATTACHMENT INVENTORY ---
  // Summary counts for quick filtering; details in EmailAttachment table
  attachmentCount       Int  @default(0)
  totalAttachmentBytes  Int  @default(0)
  hasProcessedAttachments Boolean @default(false) // At least one attachment was OCR'd

  // --- CLUSTERING METADATA ---
  clusteringConfidence  Float?          // 0-1: how confident the case assignment is
  alternativeCaseId     String?         // Next-best case match (for "might belong in" hints)
  
  // Routing decision audit trail
  routingDecision       Json?           // { route, method, confidence, reason }
  
  // --- CASE ASSIGNMENT ---
  // An email belongs to at most one case (via CaseEmail junction)
  caseEmails            CaseEmail[]

  // --- ATTACHMENTS ---
  attachments           EmailAttachment[]

  // --- LIFECYCLE ---
  isExcluded            Boolean @default(false) // User marked "exclude from scans"
  excludeReason         String?                 // Why: "user_action", "rule:domain", "rule:keyword"
  processedAt           DateTime @default(now()) // When first processed
  reprocessedAt         DateTime?               // If ever re-extracted

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([schemaId, gmailMessageId])
  @@index([schemaId, entityId])
  @@index([schemaId, threadId])
  @@index([schemaId, date])
  @@index([schemaId, senderDomain])
  @@index([schemaId, isExcluded])
  @@map("emails")
}


// =============================================================================
// EMAIL ATTACHMENT — Normalized Attachment Inventory
// =============================================================================
//
// Separate table for queryability: "find all invoices" or "all PDFs from this vendor"
// The extractionSummary is the bridge between "we know this exists" and
// "we need to re-fetch it for detail."
// =============================================================================

model EmailAttachment {
  id            String   @id @default(cuid())
  emailId       String
  email         Email    @relation(fields: [emailId], references: [id], onDelete: Cascade)

  // --- GMAIL REFERENCE ---
  gmailAttachmentId  String             // For targeted re-fetch from Gmail API

  // --- FILE METADATA ---
  filename          String              // "invoice-2026-03.pdf"
  mimeType          String              // "application/pdf", "image/jpeg"
  sizeBytes         Int                 // File size
  
  // --- PROCESSING STATUS ---
  processed         Boolean @default(false)  // Did Gemini Vision process this?
  processedFully    Boolean @default(false)  // Was the entire document processed?
  processedPages    Int?                     // How many pages were processed (PDFs)
  totalPages        Int?                     // Total pages in document (PDFs)
  processingError   String?                  // If processing failed, why

  // --- EXTRACTION RESULTS ---
  // The critical "bridge" field: detailed enough to triage, cheap enough to store
  extractionSummary   String?  @db.Text      // "Invoice from Comfort Air, $8,200 for HVAC install, 10-year warranty"
  extractedData       Json     @default("{}") // Schema-defined fields from this specific attachment
  
  // --- DOCUMENT CLASSIFICATION ---
  documentType        String?               // "invoice", "contract", "photo", "report", "correspondence", "unknown"
  hasHandwriting      Boolean @default(false) // Scanned/signed document detection
  hasImages           Boolean @default(false) // Contains photos or diagrams
  
  createdAt           DateTime @default(now())

  @@index([emailId])
  @@index([documentType])
  @@map("email_attachments")
}


// =============================================================================
// CASE — Clustered Email Groups with AI-Generated Summaries
// =============================================================================

model Case {
  id            String   @id @default(cuid())
  schemaId      String
  schema        CaseSchema @relation(fields: [schemaId], references: [id], onDelete: Cascade)

  // --- ENTITY SCOPE ---
  entityId      String                  // Primary entity this case belongs to
  entity        Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)

  // --- AI-GENERATED CONTENT ---
  title         String                  // "Kitchen Remodel Permits"
  emoji         String?                 // AI-assigned emoji for visual identification (e.g., "⚽", "🏠")
  summary       Json                    // { beginning: "...", middle: "...", end: "..." }
  
  // Primary actor: the main counterparty in this case (AI-identified during synthesis)
  primaryActor  Json?                   // { name: "City Planning Dept", entityType: "Vendor" }

  // --- TAGS ---
  // Display tags: human-facing, AI-curated during synthesis (2-3 tags)
  displayTags   Json     @default("[]") // ["Permits", "Timeline"]
  
  // Clustering tags: engine-facing, used for merge scoring
  anchorTags    Json     @default("[]") // Top 1-2 strongest clustering tags
  anchorTagLastUsed  Json @default("{}") // { "Permits": "2026-03-01T..." } per-tag time decay
  allTags       Json     @default("[]") // All accumulated tags from all emails

  // --- STATUS ---
  status        CaseStatus @default(OPEN)
  urgency       String?    @default("UPCOMING")  // IMMINENT | THIS_WEEK | UPCOMING | NO_ACTION | IRRELEVANT

  // --- CONFIGURABLE AGGREGATED DATA ---
  // Rolled up from email-level extractedData per ExtractedFieldDef.aggregation
  aggregatedData  Json   @default("{}") // { cost: 2400, deadline: "2026-04-15" }

  // --- DATES ---
  startDate     DateTime?               // Earliest email date in case
  endDate       DateTime?               // Most recent email date in case

  // --- DENORMALIZED FOR FEED PERFORMANCE ---
  lastSenderName    String?             // Display name of most recent email sender
  lastSenderEntity  String?             // Enriched: "Mike Chen, City Planning"
  lastEmailDate     DateTime?           // Date of most recent email in case

  // --- SYNTHESIS TRACKING ---
  synthesizedAt DateTime?               // Set when synthesis completes; used to skip re-synthesis

  // --- USER INTERACTION ---
  viewedAt      DateTime?               // null = unread, set when user opens case
  lastFeedbackAt DateTime?              // When user last gave thumbs up/down
  feedbackRating String?                // "up" | "down" | null (most recent)
  
  // --- RELATIONSHIPS ---
  caseEmails    CaseEmail[]
  actions       CaseAction[]
  feedbackEvents FeedbackEvent[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([schemaId, entityId])
  @@index([schemaId, status])
  @@index([schemaId, status, urgency])
  @@index([schemaId, viewedAt])
  @@map("cases")
}

enum CaseStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}


// =============================================================================
// CASE-EMAIL JUNCTION
// =============================================================================
//
// An email belongs to at most one case within a schema.
// The junction table tracks HOW the email was assigned (for debugging and learning).
// =============================================================================

model CaseEmail {
  id            String   @id @default(cuid())
  caseId        String
  case          Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  emailId       String
  email         Email    @relation(fields: [emailId], references: [id], onDelete: Cascade)

  // How this assignment happened
  assignedBy    AssignmentMethod @default(CLUSTERING) 
  assignedAt    DateTime @default(now())
  
  // Score at time of assignment (for debugging)
  clusteringScore  Float?              // The gravity model score when assigned
  
  // Was this assignment ever corrected?
  wasReassigned    Boolean @default(false) // True if user moved this email away
  reassignedAt     DateTime?
  reassignedTo     String?              // Case ID it was moved to

  @@unique([caseId, emailId])
  @@unique([emailId])   // An email can only be in one case
  @@index([caseId])
  @@index([emailId])
  @@map("case_emails")
}

enum AssignmentMethod {
  CLUSTERING    // Gravity model assigned it
  USER_MOVE     // User manually moved it here
  USER_CREATE   // User created a new case with this email
  MERGE         // Case merge brought it here
  COPILOT       // AI co-pilot recommended and user approved
}


// =============================================================================
// CASE ACTION — Extracted Action Items with Dedup and Lifecycle
// =============================================================================
//
// Actions are the "what do I need to do" layer on top of cases.
// AI-extracted from email content during synthesis, deduped against existing
// actions on the same case.
//
// Key behaviors:
//   - Reminder emails add to sourceEmailIds, don't create new actions
//   - Due date changes update the existing action, log the change
//   - Completion can be user-marked or AI-inferred (reply saying "done")
//   - Calendar sync is one-way: action -> Google Calendar event
//
// The action lifecycle:
//   Email arrives -> AI extracts action candidates -> Dedup against existing
//   actions on this case -> Create new or update existing -> Surface in UI
//   -> User marks done (or AI detects completion) -> Action resolved
// =============================================================================

model CaseAction {
  id            String   @id @default(cuid())
  caseId        String
  case          Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  schemaId      String   // Denormalized for query efficiency

  // --- WHAT ---
  title         String                  // "Sign permission slip for Denver Zoo field trip"
  description   String?  @db.Text       // Additional context if needed
  actionType    ActionType @default(TASK) // task, event, payment, deadline

  // --- WHEN ---
  dueDate       DateTime?               // Extracted or inferred due date
  dueDateSource String?                 // Email ID that established or last changed due date
  eventStartTime DateTime?              // For events: specific start time
  eventEndTime   DateTime?              // For events: end time
  eventLocation  String?                // For events: "Oak Park Field", "School Gym"

  // --- RECURRENCE (Phase 2) ---
  isRecurring        Boolean @default(false)  // "Practice every Tuesday and Thursday"
  recurrenceRule     String?                  // iCal RRULE: "FREQ=WEEKLY;BYDAY=TU,TH"
  recurrenceEndDate  DateTime?               // When recurrence ends (end of season, etc.)

  // --- STATUS ---
  status        ActionStatus @default(PENDING)
  completedAt   DateTime?
  completedBy   ActionCompletionSource?  // How it was marked done

  // --- PROVENANCE ---
  // Which emails generated, updated, or confirmed this action
  sourceEmailIds      Json  @default("[]")  // All emails that reference this action
  createdByEmailId    String?               // Email that first generated this action
  lastUpdatedByEmailId String?              // Email that most recently changed this action

  // --- DEDUP TRACKING ---
  // Hash of normalized title for fast dedup matching
  // When a new email's action candidate matches an existing action's fingerprint,
  // we update rather than create
  fingerprint         String?               // Normalized: lowercase, stop words removed, stemmed
  reminderCount       Int     @default(0)   // How many emails were reminders for this action

  // --- CHANGE LOG ---
  // Track what changed and when (for the "7 reminders" transparency)
  changeLog           Json    @default("[]") // [{ date, field, oldValue, newValue, emailId }]
  // Example: [{ date: "2026-03-12", field: "dueDate", oldValue: "2026-03-10",
  //             newValue: "2026-03-14", emailId: "em_xxx" }]

  // --- CALENDAR SYNC ---
  calendarEventId     String?               // Google Calendar event ID if synced
  calendarSynced      Boolean @default(false)
  calendarSyncedAt    DateTime?

  // --- AI CONFIDENCE ---
  confidence    Float   @default(0.8)       // How confident the AI is this is a real action
  // Low confidence actions could be shown with a "?" indicator in the UI

  // --- FINANCIAL (for payment-type actions) ---
  amount        Float?                      // Dollar amount if this is a payment action
  currency      String?  @default("USD")

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([caseId, status])
  @@index([schemaId, status])
  @@index([schemaId, dueDate])
  @@index([fingerprint])
  @@map("case_actions")
}

enum ActionType {
  TASK          // "Sign permission slip", "Submit registration form"
  EVENT         // "Soccer practice Tuesday 5:30pm", "Spring concert March 20"
  PAYMENT       // "Pay $125 registration fee", "Invoice due"
  DEADLINE      // "Permit application due March 15"
  RESPONSE      // "Reply to coach about availability"
}

enum ActionStatus {
  PENDING       // Not done yet
  DONE          // User marked or AI detected completion
  EXPIRED       // Past due date, never completed
  SUPERSEDED    // Replaced by an updated version (deadline changed)
  DISMISSED     // User said "not relevant"
}

enum ActionCompletionSource {
  USER          // User tapped "done" in the UI
  INFERRED      // AI detected completion from email content ("signed and sent")
  CALENDAR      // Inferred from calendar event passing
}


// =============================================================================
// CLUSTER — Audit Trail for Clustering Decisions
// =============================================================================

model Cluster {
  id            String   @id @default(cuid())
  schemaId      String
  schema        CaseSchema @relation(fields: [schemaId], references: [id], onDelete: Cascade)

  // What this cluster decided
  action        ClusterAction           // MERGE into existing case or CREATE new case
  targetCaseId  String?                 // For MERGE: which case to merge into
  clusterPass   String?                 // "COARSE" | "SPLIT" — which pass created this
  
  // Cluster contents
  emailIds      Json     @default("[]") // Email IDs in this cluster
  threadIds     Json     @default("[]") // Unique thread IDs

  // Scoring snapshot (for debugging)
  score         Float?                  // Highest score against existing cases
  primaryTag    String?                 // Dominant tag in cluster
  scoreBreakdown Json?                  // { threadScore, tagScore, subjectScore, ... }

  // Processing status
  status        ClusterStatus @default(PENDING)
  
  // Result: which case was created or merged into
  resultCaseId  String?

  // Scan job that created this cluster
  scanJobId     String?

  createdAt     DateTime @default(now())

  @@index([schemaId])
  @@index([scanJobId])
  @@map("clusters")
}

enum ClusterAction {
  MERGE
  CREATE
}

enum ClusterStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}


// =============================================================================
// FEEDBACK EVENTS — Every User Correction and Rating
// =============================================================================
//
// First-class data. Every interaction that teaches the system is logged here.
// The breaking-in curve is computed from this table.
// =============================================================================

model FeedbackEvent {
  id            String   @id @default(cuid())
  schemaId      String
  schema        CaseSchema @relation(fields: [schemaId], references: [id], onDelete: Cascade)

  // What happened
  eventType     FeedbackType

  // Context (which case/email was affected)
  caseId        String?
  case          Case?    @relation(fields: [caseId], references: [id], onDelete: SetNull)
  emailId       String?                 // For email-level actions (move, exclude)
  
  // Event-specific payload
  payload       Json                    // Structure depends on eventType, see below
  // THUMBS_UP:     { caseId }
  // THUMBS_DOWN:   { caseId, reason: "wrong_group" | "missing" | "not_useful" }
  // EMAIL_MOVE:    { emailId, fromCaseId, toCaseId }
  // EMAIL_EXCLUDE: { emailId, senderDomain, senderEmail }
  // CASE_MERGE:    { sourceCaseId, targetCaseId }
  // CASE_SPLIT:    { originalCaseId, newCaseIds[] }
  // TAG_EDIT:      { action: "add"|"remove"|"rename", tagName, newTagName? }
  // ENTITY_MERGE:  { sourceEntityId, targetEntityId }
  // ENTITY_EDIT:   { entityId, action: "rename"|"add_alias"|"remove", ... }

  // What the system learned (filled in by the correction processor)
  schemaAdjustment  Json?              // What parameter changed as a result
  // Example: { field: "tag_weight", tag: "Permits", oldValue: 1.0, newValue: 1.2 }

  createdAt     DateTime @default(now())

  @@index([schemaId, eventType])
  @@index([schemaId, createdAt])
  @@index([caseId])
  @@map("feedback_events")
}

enum FeedbackType {
  THUMBS_UP
  THUMBS_DOWN
  EMAIL_MOVE
  EMAIL_EXCLUDE
  CASE_MERGE
  CASE_SPLIT
  TAG_EDIT
  ENTITY_MERGE
  ENTITY_EDIT
}


// =============================================================================
// QUALITY SNAPSHOTS — Daily Accuracy Tracking
// =============================================================================
//
// Computed daily (or after each scan). Tracks the breaking-in curve.
// Rolling 30-day window.
// =============================================================================

model QualitySnapshot {
  id            String   @id @default(cuid())
  schemaId      String
  schema        CaseSchema @relation(fields: [schemaId], references: [id], onDelete: Cascade)

  // Snapshot date
  date          DateTime @db.Date

  // Signals in the window
  casesViewed       Int  @default(0)
  thumbsUp          Int  @default(0)
  thumbsDown        Int  @default(0)
  emailMoves        Int  @default(0)   // Corrections: emails moved between cases
  emailExcludes     Int  @default(0)   // Emails excluded from scans
  caseMerges        Int  @default(0)
  caseSplits        Int  @default(0)

  // Computed accuracy: 1 - (corrections / casesViewed)
  // Where corrections = thumbsDown + emailMoves + caseMerges + caseSplits
  accuracy          Float?             // null if insufficient signals
  totalCorrections  Int  @default(0)
  totalSignals      Int  @default(0)   // All interactions (views + ratings + corrections)

  // Phase
  phase             QualityPhase @default(CALIBRATING)

  createdAt         DateTime @default(now())

  @@unique([schemaId, date])
  @@index([schemaId, date])
  @@map("quality_snapshots")
}

enum QualityPhase {
  CALIBRATING   // Not enough signals for a score
  TRACKING      // Score is being computed
  STABLE        // Accuracy above 95% for 7+ consecutive days
}


// =============================================================================
// EXCLUSION RULES — Learned from User "Exclude" Actions
// =============================================================================
//
// When a user excludes emails, the system detects patterns and creates rules.
// 3 excludes from same domain -> suggest domain rule.
// =============================================================================

model ExclusionRule {
  id            String   @id @default(cuid())
  schemaId      String
  schema        CaseSchema @relation(fields: [schemaId], references: [id], onDelete: Cascade)

  ruleType      ExclusionRuleType       // DOMAIN, KEYWORD, SENDER, THREAD
  pattern       String                  // "schwab.com", "automatic reply", "noreply@company.com"
  
  // How the rule was created
  source        String   @default("user")  // "user" | "system_suggested" | "interview"
  
  // How many emails this rule has matched
  matchCount    Int      @default(0)
  
  isActive      Boolean  @default(true)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([schemaId, ruleType, pattern])
  @@index([schemaId, isActive])
  @@map("exclusion_rules")
}

enum ExclusionRuleType {
  DOMAIN        // Entire sender domain: "schwab.com"
  KEYWORD       // Subject/body keyword: "automatic reply"
  SENDER        // Specific sender: "noreply@company.com"
  THREAD        // Specific Gmail thread ID
}


// =============================================================================
// SCAN JOBS — Processing Pipeline Tracking
// =============================================================================

model ScanJob {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  schemaId      String
  schema        CaseSchema @relation(fields: [schemaId], references: [id], onDelete: Cascade)

  // Job status
  status        JobStatus    @default(PENDING)
  phase         ScanPhase    @default(IDLE)
  
  // Progress tracking
  totalEmails       Int  @default(0)    // Total emails found in Gmail search
  processedEmails   Int  @default(0)    // Emails processed so far
  newEmails         Int  @default(0)    // Emails not previously seen
  excludedEmails    Int  @default(0)    // Emails skipped by exclusion rules
  failedEmails      Int  @default(0)    // Emails that failed processing
  
  // Synthesis progress
  clustersCreated   Int  @default(0)
  casesMerged       Int  @default(0)
  casesCreated      Int  @default(0)

  // Cost tracking
  totalInputTokens  Int  @default(0)
  totalOutputTokens Int  @default(0)
  estimatedCostUsd  Float @default(0)

  // Trigger
  triggeredBy       String @default("manual")  // "manual" | "scheduled" | "onboarding"
  
  // Status message (for UI display)
  statusMessage     String?
  
  // Error info
  errorMessage      String?  @db.Text
  
  pipelineIntelligence PipelineIntelligence[]

  startedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([schemaId, status])
  @@index([userId])
  @@map("scan_jobs")
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum ScanPhase {
  IDLE
  DISCOVERING         // Finding emails via Gmail search
  EXTRACTING          // Processing emails through AI pipeline
  CLUSTERING          // Running gravity model
  SYNTHESIZING        // AI generating case titles/summaries
  COMPLETED
  FAILED
}


// =============================================================================
// PIPELINE INTELLIGENCE — AI Reasoning at Each Pipeline Stage
// =============================================================================
//
// Stores AI reasoning for debugging, learning, and audit.
// - Discovery: sender patterns, social graph, body samples, generated queries
// - Clustering: proposed email groups, config overrides, AI reasoning
// =============================================================================

model PipelineIntelligence {
  id          String   @id @default(cuid())
  schemaId    String
  scanJobId   String?
  stage       String   // "discovery" | "clustering" | "extraction_summary"
  input       Json     // what was sent to the AI (compact)
  output      Json     // what the AI returned
  model       String   // which model was used
  tokenCount  Int?     // total tokens for cost tracking
  createdAt   DateTime @default(now())

  schema      CaseSchema @relation(fields: [schemaId], references: [id], onDelete: Cascade)
  scanJob     ScanJob?   @relation(fields: [scanJobId], references: [id])

  @@index([schemaId, stage])
  @@map("pipeline_intelligence")
}


// =============================================================================
// EXTRACTION COST LOG
// =============================================================================
//
// Per-email token usage for cost tracking and optimization.
// Aggregated into ScanJob totals but kept granular for analysis.
// =============================================================================

model ExtractionCost {
  id            String   @id @default(cuid())
  emailId       String
  scanJobId     String?

  // What was processed
  model         String                  // "gemini-2.5-flash", "claude-opus-4-6"
  operation     String                  // "extraction", "synthesis", "routing", "copilot"
  
  // Token counts
  inputTokens   Int
  outputTokens  Int
  
  // Estimated cost
  estimatedCostUsd  Float

  // Timing
  latencyMs     Int?                    // How long the API call took
  
  createdAt     DateTime @default(now())

  @@index([scanJobId])
  @@index([emailId])
  @@index([createdAt])
  @@map("extraction_costs")
}
